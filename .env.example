# Public browser configuration. The Supabase anon key is safe to expose only
# when every public table and Storage bucket is protected by RLS.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
PUBLIC_SITE_URL=http://127.0.0.1:4173

# Server-only values. Add these to Supabase Edge Function secrets / Vercel,
# never to cms-config.js and never commit real values.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY
CMS_BOOTSTRAP_SECRET=GENERATE_A_LONG_RANDOM_SECRET
ALLOWED_ADMIN_ORIGIN=http://127.0.0.1:4173
ADMIN_SITE_URL=http://127.0.0.1:4173/admin/
